rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // [D4] Document-level write rate-limit helper.
    // Prevents direct-to-Firestore write floods that bypass the API layer.
    // Returns true (allowing the write) when:
    //   - The document has no 'lastWrite' timestamp yet (first write), OR
    //   - The interval since the last recorded write exceeds minIntervalSecs.
    // Backend writes via Admin SDK set 'lastWrite' automatically;
    // this guard fires only for client-SDK writes that have a valid auth token
    // but are bypassing the Flask API.
    function notTooRecent(minIntervalSecs) {
      return !('lastWrite' in resource.data) ||
        request.time > resource.data.lastWrite + duration.value(minIntervalSecs, 's');
    }

    // [D4] Prevent clients from escalating privileges or patching subscription
    // state directly on the user document. Backend (Admin SDK) bypasses this.
    function userWriteIsAllowed() {
      let restricted = ['role', 'is_admin', 'subscription'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(restricted);
    }

    // ─── Default: deny everything ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // [D4] Clients cannot write to role, is_admin, or subscription fields
      allow update: if isOwner(userId) && userWriteIsAllowed();
      allow delete: if isAdmin();

      // User sub-collections: mood subcollection (alternative path to /moods)
      match /moods/{moodId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        // [D4] Rate-limit direct client updates to this subcollection: max 1/5 s
        allow update: if isOwner(userId) && notTooRecent(5);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /memories/{memoryId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /journal/{entryId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /conversations/{convId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /chats/{chatId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /meditation_sessions/{sessionId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // ─── Root-level mood entries ─────────────────────────────────
    match /moods/{moodId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // [D4] Rate-limit direct client mood updates: max 1 per 5 seconds
      allow update: if isAuthenticated() &&
        resource.data.user_id == request.auth.uid &&
        notTooRecent(5);
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Memories ───────────────────────────────────────────────
    match /memories/{memoryId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Chat sessions ───────────────────────────────────────────
    match /chat_sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Achievements ────────────────────────────────────────────
    match /achievements/{achievementId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if false;
    }

    // ─── Feedback ────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ─── Referrals ───────────────────────────────────────────────
    // [D4] Clients can create and read their own outgoing referrals.
    //      Updates and deletes are fully blocked for clients — only the
    //      backend (Admin SDK, which bypasses rules) may mark a referral
    //      as used or change its state.  This prevents referral-code abuse
    //      (e.g., forging completion, self-referral bypasses).
    //      Note: old rule used resource.data.user_id; referral docs store
    //      the owner as referrer_id — corrected here.
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (
        resource.data.referrer_id == request.auth.uid ||
        resource.data.referred_id == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.referrer_id == request.auth.uid;
      // [D4] Block ALL client-side updates — prevents referral abuse
      allow update, delete: if false;
    }

    // ─── Subscriptions (backend-only) ────────────────────────────
    // [D4] The /subscriptions collection must NOT be readable by clients.
    //      Subscription status for UI purposes is available on the user
    //      document (read above). This collection is written exclusively
    //      by the backend via Stripe webhooks and Admin SDK.
    match /subscriptions/{subId} {
      allow read, write: if false;
    }

    // ─── Audit logs (admin read-only) ────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ─── Password reset tokens (backend-only) ────────────────────
    // [D4] Tokens are stored/verified server-side only; no client access.
    match /password_reset_tokens/{tokenId} {
      allow read, write: if false;
    }

    // ─── Breathing sessions ──────────────────────────────────────
    match /breathing_sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // [D4] Rate-limit direct client updates: max 1 per 5 seconds
      allow update: if isAuthenticated() &&
        resource.data.user_id == request.auth.uid &&
        notTooRecent(5);
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Challenges (read-only for users) ────────────────────────
    // Write operations go through the API (Admin SDK), not client SDK.
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ─── Forecast history ────────────────────────────────────────
    match /forecast_history/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Sync history (append-only for users) ────────────────────
    match /sync_history/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Peer chat messages ──────────────────────────────────────
    // [DB2] Authenticated users can read/create messages in rooms they belong to.
    // Only admins or the owning user can delete. Updates are blocked client-side
    // to prevent message tampering (backend Admin SDK handles edits).
    match /peer_chat_messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.sender_id == request.auth.uid ||
        resource.data.recipient_id == request.auth.uid ||
        resource.data.room_participants.hasAny([request.auth.uid])
      );
      allow create: if isAuthenticated() &&
        request.resource.data.sender_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ─── User challenges ─────────────────────────────────────────
    // [DB2] Users can read/join their own challenge participation records.
    // Completion and scoring is written by backend only.
    match /user_challenges/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;
      // Backend Admin SDK records completion; block client progress tampering.
      allow update, delete: if false;
    }

    // ─── Reward profiles ─────────────────────────────────────────
    // [DB2] XP and badge profiles: users can read their own.
    // Writes come exclusively from the backend reward engine.
    match /reward_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if false;
    }

    // ─── User devices (OAuth-connected) ──────────────────────────
    // [DB2] Users can read their own device records; backend manages linking.
    match /user_devices/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;
      // Delinking goes through the API; block direct client deletes.
      allow update, delete: if false;
    }

    // ─── Journal entries (root-level) ────────────────────────────
    // [DB2] Encrypted entries; only the owner can read or write.
    match /journal_entries/{entryId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Onboarding data ─────────────────────────────────────────
    // [DB2] Onboarding answers stored per user.
    match /onboarding_data/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Allow updates (user may redo onboarding); deletes blocked except admin.
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // ─── Daily usage quota ────────────────────────────────────────
    // [DB2] Usage counters track daily API consumption per user.
    // Users can read their own quota; the backend increments counters.
    match /usage/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      // Block all client-side writes — updated exclusively by backend.
      allow create, update, delete: if false;
    }

    // ─── AI chat history ─────────────────────────────────────────
    // [DB2] Top-level chat_history docs are written by the backend AI service.
    // Users can read their own conversation history read-only.
    match /chat_history/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      // Created and updated only by backend (Admin SDK).
      allow create, update, delete: if false;
    }

    // ─── AI-generated stories ────────────────────────────────────
    // [DB2] AI stories are generated server-side and read-only for users.
    match /ai_stories/{docId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create, update, delete: if false;
    }
  }
}
