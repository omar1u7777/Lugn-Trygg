# ==========================================
# Lugn-Trygg Environment Variables Template
# ==========================================
# 
# ⚠️  IMPORTANT SECURITY NOTES:
# 1. NEVER commit the actual .env file to git!
# 2. Copy this file to .env and fill in YOUR actual values
# 3. Generate secure keys for production (see instructions below)
# 4. Keep all credentials secret and rotate them regularly
#
# ==========================================

# 🔗 Backend API URL
# Development: http://localhost:5001
# Production: Your deployed backend URL (e.g., https://api.yourdomain.com)
VITE_BACKEND_URL=http://localhost:5001

# 🔥 Firebase Configuration (REQUIRED)
# Get these from: https://console.firebase.google.com/project/YOUR_PROJECT/settings/general
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# 🔔 Firebase Cloud Messaging (Optional)
# Get VAPID key from: Firebase Console > Project Settings > Cloud Messaging
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# 🔐 Client-Side Encryption Key (REQUIRED) [S3]
# ⚠️  CRITICAL: Generate a secure 64-character random hex string for production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or online: https://www.random.org/strings/?num=1&len=64&digits=on&upperalpha=on&loweralpha=on
# ⚠️  MUST be IDENTICAL to ENCRYPTION_KEY in the backend environment (Backend/.env).
# If these differ, all client-encrypted data will be unreadable by the backend.
VITE_ENCRYPTION_KEY=your_secure_64_character_hex_encryption_key_replace_this_in_production

# 🌐 Google OAuth (Optional)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ☁️ Cloudinary CDN (Optional)
# Get from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
# Dashboard hero illustration (public ID inside your Cloudinary account)
VITE_DASHBOARD_HERO_PUBLIC_ID=branding/world-class-dashboard-hero-v1
# Wellness Hub hero illustration
VITE_WELLNESS_HERO_PUBLIC_ID=branding/wellness-hub-hero-v1
# Journal Hub hero illustration
VITE_JOURNAL_HERO_PUBLIC_ID=branding/journal-hub-hero-v1
# Onboarding Flow hero illustration
VITE_ONBOARDING_HERO_PUBLIC_ID=branding/onboarding-flow-hero-v1

# 📊 Analytics (Optional)
# Amplitude: https://analytics.amplitude.com
VITE_AMPLITUDE_API_KEY=your_amplitude_key

# 🐛 Error Tracking (Optional)
# Sentry: https://sentry.io
VITE_SENTRY_DSN=your_sentry_dsn

# 📈 Vercel Analytics (Optional)
VITE_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# ⚡ Performance Monitoring (Optional)
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1
VITE_ENABLE_WEB_VITALS=true

# 🧪 Development Flags (Optional - DO NOT enable in production!)
VITE_FORCE_ANALYTICS=false
VITE_ENABLE_TEST_PROVIDERS=false
VITE_ENABLE_DEBUG_MODE=false

# ==========================================
# SECURITY CHECKLIST FOR PRODUCTION:
# ==========================================
# ✅ All values set to production credentials (not dev/test)
# ✅ VITE_ENCRYPTION_KEY is a unique, randomly generated 64-char hex string
# ✅ Firebase keys are from production Firebase project
# ✅ VITE_BACKEND_URL points to production API (HTTPS required!)
# ✅ .env file added to .gitignore (NEVER commit!)
# ✅ Secrets rotated regularly (quarterly recommended)
# ✅ No hardcoded fallback values in source code
# ✅ Test flags disabled (VITE_ENABLE_TEST_PROVIDERS=false)
# ==========================================
